flowchart TB
  subgraph L1["接入层"]
    U1["平台管理员"]
    U2["城市管理员"]
    U3["教研老师"]
    U4["查看角色"]
  end

  subgraph L2["应用层"]
    W1["管理后台前端<br/>React + Vite"]
    W2["管理后台 API<br/>Flask"]
  end

  subgraph L3["业务能力层"]
    B1["权限与租户管理<br/>城市隔离 / 角色权限 / 平台配置"]
    B2["教材处理中心<br/>上传教材 / 自动切片 / 图片解析 / 参考题映射"]
    B3["人工审核中心<br/>切片核对 / 映射确认 / 教材生效"]
    B4["智能出题中心<br/>模板规划 / AI 出题 / 任务续跑 / 缺口补齐"]
    B5["质量运营中心<br/>离线 Judge / QA 评估 / 告警 / 趋势分析"]
    B6["版本与题库中心<br/>版本发布 / 题库管理 / 导出交付 / 持续优化"]
  end

  subgraph L4["数据与运行层"]
    D1["运行配置<br/>Key 文件 / 城市配置 / 用户绑定"]
    D2["租户业务数据<br/>教材 / 切片 / 映射 / 题库 / 导出"]
    D3["过程数据<br/>任务快照 / QA runs / 发布记录 / 审计日志"]
    D4["运行环境<br/>Runtime / Cache / SQLite 或 PostgreSQL"]
  end

  subgraph L5["外部能力层"]
    X1["大模型服务<br/>AIT / OpenAI 兼容 / Ark"]
    X2["离线 Judge 能力"]
    X3["Git 仓库"]
  end

